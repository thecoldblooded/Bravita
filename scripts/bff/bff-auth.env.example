# Bravita BFF auth runtime
# Copy to /etc/bravita/bff-auth.env on server and secure with chmod 600

NODE_ENV=production
BFF_AUTH_HOST=127.0.0.1
BFF_AUTH_PORT=3901
BFF_MAX_BODY_BYTES=1048576

# Required: used by api/auth/_shared.js
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Required for phone-verified signup/profile updates.
# This is the Firebase Web API key used by Identity Toolkit token lookup.
FIREBASE_API_KEY=your-firebase-web-api-key

# Origin allowlists
SITE_URL=https://bravita.com.tr
ALLOWED_AUTH_ORIGINS=https://bravita.com.tr,https://www.bravita.com.tr
ALLOWED_RECOVERY_REDIRECT_ORIGINS=https://bravita.com.tr,https://www.bravita.com.tr
