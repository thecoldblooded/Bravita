# Supabase Configuration
# Get these values from your Supabase project dashboard
# https://app.supabase.com/

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SITE_URL=https://bravita.com.tr
VITE_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key

# BFF Auth Mode (set true to use /api/auth httpOnly-cookie bridge)
VITE_USE_BFF_AUTH=true
VITE_BFF_AUTH_TARGET=http://127.0.0.1:3901

# Serverless API fallback vars (Vercel/Node runtime)
# If not set, api/auth routes fall back to VITE_* values above.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SITE_URL=https://bravita.com.tr
AUTH_SITE_URL=https://bravita.com.tr
ALLOWED_AUTH_ORIGINS=https://bravita.com.tr,https://www.bravita.com.tr
ALLOWED_RECOVERY_REDIRECT_ORIGINS=https://bravita.com.tr,https://www.bravita.com.tr
HCAPTCHA_SECRET_KEY=your-hcaptcha-secret-key
AUTH_DEBUG_LOGS=false
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=10
AUTH_SESSION_READ_RATE_LIMIT_MAX_REQUESTS=30

# CounterAPI visitor counter (server-side only; do not expose as VITE_*)
COUNTERAPI_TOKEN=your-counterapi-token
COUNTERAPI_WORKSPACE=your-counterapi-workspace
COUNTERAPI_COUNTER_NAME=your-counterapi-counter-name
COUNTERAPI_ALLOWED_ORIGINS=https://bravita.com.tr,https://www.bravita.com.tr

# Google OAuth Configuration
# Optional: Configure in Supabase dashboard
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Client feature flags
VITE_PAYMENT_USE_TOKENIZATION=false
VITE_PAYMENT_TOKENIZATION_REQUIRED=false

# Supabase Edge Function secrets (set in Supabase, not Vercel)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
APP_BASE_URL=https://bravita.com.tr
APP_ALLOWED_ORIGINS=https://bravita.com.tr,https://www.bravita.com.tr
APP_WEBHOOK_SECRET=your-webhook-secret
PAYMENT_ALLOWED_ORIGINS=https://bravita.com.tr,https://www.bravita.com.tr
PAYMENT_MAINTENANCE_SECRET=your-maintenance-secret
PAYMENT_RECONCILIATION_ENABLED=true
BAKIYEM_BASE_URL=https://service.mokaunited.com
BAKIYEM_TEST_BASE_URL=https://service.refmokaunited.com
BAKIYEM_DEALER_CODE=your-bakiyem-dealer-code
BAKIYEM_API_USERNAME=your-bakiyem-api-username
BAKIYEM_API_PASSWORD=your-bakiyem-api-password
BAKIYEM_REDIRECT_URL=https://your-project.supabase.co/functions/v1/bakiyem-3d-return
THREED_PAYLOAD_ENC_KEY=your-32-byte-encryption-key
RESEND_API_KEY=your-resend-api-key
SUPPORT_EMAIL_NOTIFY=support@bravita.com.tr
BILLIONMAIL_API_URL=https://your-billionmail.example/api
BILLIONMAIL_API_KEY=your-billionmail-api-key

# CI-only quality gate secrets/options (set in GitHub Actions; local .env optional)
SOCKET_CLI_API_TOKEN=your-socket-dev-token
SOCKET_CI_ALLOW_API_FAILURE=true
SOCKET_CI_ATTEMPTS=2

# SMS Provider Configuration
# Configured in Supabase dashboard (Twilio or MessageBird)
